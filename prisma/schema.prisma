// Modelo de datos de Gamex (Fase 2).
// Mapea el dominio ya modelado en src/lib/types.ts hacia PostgreSQL.
//
// Decisiones:
// - Auth propia: User.passwordHash (email + contraseña).
// - Inventario simple: Product.stock (entero).
// - Pagos con pasarela real: Payment guarda ids/estado del proveedor + webhooks.
// - Features: cupones, reseñas, lista de deseos y carrito persistente en servidor.
// - Dinero en Decimal (nunca float). Precios base en USD; el S/ se deriva con exchangeRate.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Role {
  CLIENTE
  ADMIN
}

enum UserStatus {
  ACTIVO
  INACTIVO
}

enum OrderStatus {
  PENDIENTE
  PAGADO
  PREPARANDO
  ENVIADO
  ENTREGADO
  CANCELADO
}

enum PaymentMethod {
  TARJETA
  YAPE
  TRANSFERENCIA
}

enum PaymentProvider {
  CULQI
  MERCADO_PAGO
  STRIPE
  MANUAL
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  REEMBOLSADO
  FALLIDO
}

enum CouponType {
  PORCENTAJE
  MONTO_FIJO
}

// ----------------------------------------------------------------------------
// Usuarios y direcciones
// ----------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  phone        String?
  document     String?    // DNI / RUC
  role         Role       @default(CLIENTE)
  status       UserStatus @default(ACTIVO)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  addresses Address[]
  orders    Order[]
  reviews   Review[]
  wishlist  WishlistItem[]
  cart      Cart?

  @@index([role])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  fullName  String
  phone     String
  document  String
  region    String
  city      String
  address   String
  reference String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ----------------------------------------------------------------------------
// Catálogo
// ----------------------------------------------------------------------------

model Brand {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())

  products Product[]
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  createdAt DateTime @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  slug        String   @unique
  brandId     String
  categoryId  String
  priceUSD    Decimal  @db.Decimal(12, 2)
  stock       Int      @default(0)
  description String?
  // Especificaciones flexibles: [{ "label": "...", "value": "..." }]
  specs       Json?
  isNew       Boolean  @default(false)
  featured    Boolean  @default(false)
  onRequest   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand        Brand          @relation(fields: [brandId], references: [id])
  category     Category       @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  reviews      Review[]
  orderItems   OrderItem[]
  wishlistedBy WishlistItem[]
  cartItems    CartItem[]

  @@index([brandId])
  @@index([categoryId])
  @@index([featured])
  @@index([isNew])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int // 1..5 (validado en la capa de aplicación)
  comment   String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Un usuario reseña un producto una sola vez.
  @@unique([productId, userId])
  @@index([productId])
}

// ----------------------------------------------------------------------------
// Carrito persistente (server-side, además del estado en cliente)
// ----------------------------------------------------------------------------

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  productId String
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ----------------------------------------------------------------------------
// Cupones / descuentos
// ----------------------------------------------------------------------------

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  type           CouponType
  value          Decimal    @db.Decimal(12, 2) // % (0-100) o monto fijo en USD
  minPurchaseUSD Decimal?   @db.Decimal(12, 2)
  startsAt       DateTime?
  expiresAt      DateTime?
  maxUses        Int?
  usedCount      Int        @default(0)
  active         Boolean    @default(true)
  createdAt      DateTime   @default(now())

  orders Order[]
}

// ----------------------------------------------------------------------------
// Pedidos
// ----------------------------------------------------------------------------

model Order {
  id        String      @id @default(cuid())
  code      String      @unique // "GMX-100245"
  userId    String
  status    OrderStatus @default(PENDIENTE)

  // Importes congelados al momento de la compra (USD).
  subtotalUSD Decimal @db.Decimal(12, 2)
  discountUSD Decimal @default(0) @db.Decimal(12, 2)
  shippingUSD Decimal @default(0) @db.Decimal(12, 2)
  taxUSD      Decimal @default(0) @db.Decimal(12, 2) // IGV 18%
  totalUSD    Decimal @db.Decimal(12, 2)
  // Tipo de cambio USD->PEN aplicado en la compra (para reconstruir montos en S/).
  exchangeRate Decimal @default(3.45) @db.Decimal(10, 4)

  couponId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id])
  coupon   Coupon?        @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  payments Payment[]
  shipping OrderShipping?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Snapshot inmutable del producto al momento de la compra.
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String? // nullable: si el producto se elimina, el pedido conserva su historial
  name      String
  sku       String
  priceUSD  Decimal @db.Decimal(12, 2)
  quantity  Int

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// Snapshot de la dirección de envío del pedido (no se ve afectado si el usuario edita su dirección).
model OrderShipping {
  id        String  @id @default(cuid())
  orderId   String  @unique
  fullName  String
  phone     String
  document  String
  region    String
  city      String
  address   String
  reference String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------------
// Pagos (pasarela real + webhooks)
// ----------------------------------------------------------------------------

model Payment {
  id       String          @id @default(cuid())
  code     String          @unique // "PAY-50245"
  orderId  String
  method   PaymentMethod
  provider PaymentProvider @default(CULQI)
  amountUSD Decimal        @db.Decimal(12, 2)
  status   PaymentStatus   @default(PENDIENTE)

  // Datos del proveedor de pago.
  externalId     String? // id de transacción/cargo en la pasarela
  externalStatus String? // estado crudo reportado por la pasarela
  payload        Json? // último payload de webhook recibido

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([externalId])
}
